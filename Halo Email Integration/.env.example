# Required for local development and production.
# Generate with:
# node -e "console.log(require('crypto').randomBytes(32).toString('base64url'))"
HALO_TOKEN_ENCRYPTION_KEY=

# HaloPSA tenant origin and OAuth API application client ID.
HALO_URL=https://your-company.halopsa.com
HALO_CLIENT_ID=

# Microsoft Entra application (client) ID for the Office add-in app registration.
ADDIN_CLIENT_ID=

# Optional overrides. Defaults are derived from ADDIN_CLIENT_ID.
# ADDIN_API_AUDIENCE=api://<ADDIN_CLIENT_ID>
# ADDIN_AUTH_SCOPES=api://<ADDIN_CLIENT_ID>/access_as_user
# ADDIN_REQUIRED_SCOPE=access_as_user
